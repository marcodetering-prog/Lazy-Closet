rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidItem(data) {
      return data.keys().hasAll(['name', 'category', 'ownerId', 'imageUrl', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.category in ['Top', 'Bottom', 'Dress', 'Outerwear', 'Shoes', 'Accessory'] &&
             data.ownerId == request.auth.uid &&
             data.imageUrl is string && data.imageUrl.size() <= 1000 &&
             data.createdAt == request.time;
    }

    function isValidOutfit(data) {
      return data.keys().hasAll(['name', 'itemIds', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.itemIds is list && data.itemIds.size() > 0 && data.itemIds.size() <= 10 &&
             data.ownerId == request.auth.uid &&
             data.createdAt == request.time;
    }

    // Items Collection
    match /items/{itemId} {
      allow get: if isOwner(resource.data.ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(itemId) && isValidItem(request.resource.data);
      allow update: if isSignedIn() && 
                      isOwner(resource.data.ownerId) && 
                      isValidItem(request.resource.data) &&
                      request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner(resource.data.ownerId);
    }

    // Outfits Collection
    match /outfits/{outfitId} {
      allow get: if isOwner(resource.data.ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(outfitId) && isValidOutfit(request.resource.data);
      allow update: if isSignedIn() && 
                      isOwner(resource.data.ownerId) && 
                      isValidOutfit(request.resource.data) &&
                      request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner(resource.data.ownerId);
    }
  }
}
